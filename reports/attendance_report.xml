<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="attendance_report" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <!-- Parameters filled from XML header by JasperReportEngine -->
    <parameter name="subjectName" class="java.lang.String"/>
    <parameter name="sessionDate" class="java.lang.String"/>
    <parameter name="professor"   class="java.lang.String"/>
    <parameter name="classroom"   class="java.lang.String"/>
    <parameter name="schedule"    class="java.lang.String"/>

    <!-- Fields mapped from XML record nodes via XPath -->
    <field name="studentId" class="java.lang.String">
        <fieldDescription><![CDATA[studentId]]></fieldDescription>
    </field>
    <field name="fullName" class="java.lang.String">
        <fieldDescription><![CDATA[fullName]]></fieldDescription>
    </field>
    <field name="status" class="java.lang.String">
        <fieldDescription><![CDATA[status]]></fieldDescription>
    </field>

    <title>
        <band height="130">
            <staticText>
                <reportElement x="0" y="0" width="555" height="24"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[ATTENDANCE REPORT]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="30" width="100" height="16"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Subject:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="30" width="200" height="16"/>
                <textFieldExpression>$P{subjectName}</textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="50" width="100" height="16"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="50" width="200" height="16"/>
                <textFieldExpression>$P{sessionDate}</textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="70" width="100" height="16"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Professor:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="70" width="200" height="16"/>
                <textFieldExpression>$P{professor}</textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="90" width="100" height="16"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Classroom:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="90" width="200" height="16"/>
                <textFieldExpression>$P{classroom}</textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="110" width="100" height="16"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Schedule:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="110" width="200" height="16"/>
                <textFieldExpression>$P{schedule}</textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="22" backcolor="#333333" mode="Opaque"/>
            </rectangle>
            <staticText>
                <reportElement x="5" y="3" width="130" height="16" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Student ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="140" y="3" width="280" height="16" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Full Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="425" y="3" width="125" height="16" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="5" y="2" width="130" height="16"/>
                <textFieldExpression>$F{studentId}</textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="2" width="280" height="16"/>
                <textFieldExpression>$F{fullName}</textFieldExpression>
            </textField>
            <textField>
                <reportElement x="425" y="2" width="125" height="16"/>
                <textFieldExpression>$F{status}</textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>
