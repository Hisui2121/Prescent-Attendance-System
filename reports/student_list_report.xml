<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="student_list_report"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <!-- Parameter: class title -->
    <parameter name="classTitle" class="java.lang.String"/>

    <field name="studentId" class="java.lang.String"/>
    <field name="fullName" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Student Masterlist]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="30" width="555" height="16"/>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{classTitle}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="150" height="20"/><textElement><font isBold="true"/></textElement><text><![CDATA[Student ID]]></text></staticText>
            <staticText><reportElement x="150" y="0" width="305" height="20"/><textElement><font isBold="true"/></textElement><text><![CDATA[Full Name]]></text></staticText>
            <staticText><reportElement x="455" y="0" width="100" height="20"/><textElement><font isBold="true"/></textElement><text><![CDATA[Email]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField><reportElement x="0" y="0" width="150" height="18"/><textFieldExpression><![CDATA[$F{studentId}]]></textFieldExpression></textField>
            <textField><reportElement x="150" y="0" width="305" height="18"/><textFieldExpression><![CDATA[$F{fullName}]]></textFieldExpression></textField>
            <textField><reportElement x="455" y="0" width="100" height="18"/><textFieldExpression><![CDATA[$F{email}]]></textFieldExpression></textField>
        </band>
    </detail>

</jasperReport>